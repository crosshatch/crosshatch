{
  "name": "liminal",
  "version": "0.17.0",
  "private": true,
  "description": "Actors x Effects",
  "bugs": {
    "url": "https://github.com/crosshatch/crosshatch/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/crosshatch.git",
    "directory": "liminal"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./*.ts",
      "default": "./dist/*.js"
    },
    "./browser": {
      "types": "./browser/index.ts",
      "default": "./dist/browser/index.js"
    },
    "./cloudflare": {
      "types": "./cloudflare/index.ts",
      "default": "./dist/cloudflare/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@crosshatch/util": "workspace:*",
    "@effect-atom/atom": "catalog:",
    "@effect/ai": "catalog:",
    "@effect/experimental": "catalog:",
    "@effect/platform": "catalog:",
    "effect": "catalog:"
  }
}
