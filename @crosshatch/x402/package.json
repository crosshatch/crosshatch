{
  "name": "@crosshatch/x402",
  "version": "0.1.0-beta.1",
  "type": "module",
  "sideEffects": false,
  "license": "Apache-2.0",
  "description": "Various x402 utilities for Crosshatch.",
  "homepage": "https://crosshatch.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/crosshatch.git",
    "directory": "@crosshatch/x402"
  },
  "bugs": {
    "url": "https://github.com/crosshatch/crosshatch/issues"
  },
  "private": true,
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./*.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@crosshatch/util": "workspace:*",
    "viem": "catalog:"
  }
}
