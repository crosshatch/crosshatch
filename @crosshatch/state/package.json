{
  "name": "@crosshatch/state",
  "version": "0.1.0-beta.1",
  "private": true,
  "description": "State management and event-sourcing utilities shared between Crosshatch packages.",
  "homepage": "https://crosshatch.dev",
  "bugs": {
    "url": "https://github.com/crosshatch/crosshatch/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/crosshatch.git",
    "directory": "@crosshatch/state"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./*.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@crosshatch/util": "workspace:*",
    "@effect-atom/atom": "catalog:",
    "@effect/experimental": "catalog:",
    "@effect/platform": "catalog:",
    "effect": "catalog:"
  }
}
