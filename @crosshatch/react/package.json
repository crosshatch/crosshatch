{
  "name": "@crosshatch/react",
  "version": "0.1.0-beta.1",
  "private": true,
  "description": "Tools for integrating Crosshatch into React apps.",
  "homepage": "https://crosshatch.dev",
  "bugs": {
    "url": "https://github.com/crosshatch/crosshatch/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/crosshatch.git",
    "directory": "@crosshatch/react"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./*.ts",
      "import": "./dist/*.js"
    }
  },
  "peerDependencies": {
    "@crosshatch/ui": "workspace:*",
    "@crosshatch/util": "workspace:*",
    "@effect-atom/atom": "catalog:",
    "@effect-atom/atom-react": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/rpc": "catalog:",
    "crosshatch": "workspace:*",
    "effect": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:"
  }
}
