{
  "name": "@crosshatch/ui",
  "version": "0.1.0-beta.1",
  "type": "module",
  "sideEffects": false,
  "license": "Apache-2.0",
  "description": "React UI components shared between Crosshatch packages.",
  "homepage": "https://crosshatch.dev",
  "repository": {
    "type": "git",
