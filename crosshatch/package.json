{
  "name": "crosshatch",
  "version": "0.1.0-beta.1",
  "type": "module",
  "sideEffects": false,
  "license": "Apache-2.0",
  "description": "A non-custodial embedded stablecoin wallet that intercepts and pays x402s.",
  "homepage": "https://crosshatch.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/crosshatch.git",
    "directory": "packages/crosshatch"
  },
  "bugs": {
    "url": "https://github.com/crosshatch/crosshatch/issues"
  },
  "private": true,
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./fetch": {
      "default": "./dist/augment.js"
    },
    "./X402": {
      "types": "./X402/X402.ts",
      "default": "./dist/X402/X402.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@crosshatch/util": "workspace:*",
    "@effect-atom/atom": "catalog:",
    "@effect/ai": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-browser": "catalog:",
    "@effect/rpc": "catalog:",
    "effect": "catalog:"
  }
}
