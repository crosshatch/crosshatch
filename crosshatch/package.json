{
  "name": "crosshatch",
  "version": "0.1.0-beta.1",
  "type": "module",
  "sideEffects": false,
  "license": "Apache-2.0",
  "description": "An embeddable browser wallet that intercepts and retries 402s.",
  "homepage": "https://docs.crosshatch.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/crosshatch.git",
    "directory": "packages/crosshatch"
  },
  "bugs": {
    "url": "https://github.com/crosshatch/crosshatch/issues"
  },
  "private": true,
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./*.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@crosshatch/util": "workspace:*",
    "@crosshatch/x402": "workspace:*",
    "@effect-atom/atom": "catalog:",
    "@effect/ai": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-browser": "catalog:",
    "@effect/rpc": "catalog:",
    "@x402/core": "catalog:",
    "effect": "catalog:"
  }
}
