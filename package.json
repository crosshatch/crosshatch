    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/expect": "catalog:",
    "@vitest/web-worker": "catalog:",
    "fake-indexeddb": "catalog:",
    "happy-dom": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "ts-patch": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
